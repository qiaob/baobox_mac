    "claudecode.settings.config.modelHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Model alias written to settings.json; 'Follow default' removes the key." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "写入 settings.json 的模型别名；「跟随默认」则移除该键。" } } } },
    "claudecode.settings.config.cleanup" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Session retention" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "会话保留天数" } } } },
    "claudecode.settings.config.cleanup.default" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Follow default" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "跟随默认" } } } },
    "claudecode.settings.config.cleanup.days %lld" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "%lld days" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "%lld 天" } } } },
    "claudecode.settings.config.cleanupHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Sessions older than this are auto-cleaned by Claude Code; 'Follow default' removes the key." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "早于该天数的会话会被 Claude Code 自动清理；「跟随默认」则移除该键。" } } } },
