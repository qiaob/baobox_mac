    "caffeinate.preset.2h" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "On for 2 hours" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开启 2 小时" } } } },
    "caffeinate.preset.infinite" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "On indefinitely" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无限期开启" } } } },
    "caffeinate.menu.stop" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Turn Off" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "关闭" } } } },
    "caffeinate.error.title" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Could Not Enable Keep Awake" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无法开启防休眠" } } } },
    "caffeinate.error.message %lld" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The system failed to create a power assertion (error %lld)." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "系统未能创建电源管理断言（错误码 %lld）。" } } } },
    "caffeinate.settings.intro" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Keep Awake temporarily prevents your Mac from sleeping — useful for long builds, large downloads, or other unattended tasks. Click \"Keep Awake\" in the menu bar to start it for the default duration below; it turns off automatically when time is up. By default only system sleep is blocked (the screen may still turn off); enable the option below to also keep the display on." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "防休眠会临时阻止 Mac 自动进入睡眠，适合跑构建、下载大文件等需要挂机的场景。在菜单栏点击「防休眠」即按下方默认时长开启，到点自动关闭。默认只阻止系统休眠（屏幕仍会正常熄灭），如需屏幕常亮可打开下方选项。" } } } },
    "caffeinate.settings.durationSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Default Duration" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "默认时长" } } } },
    "caffeinate.settings.durationPicker" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Duration for menu and quick start" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "菜单点击或快捷开启时的时长" } } } },
    "caffeinate.settings.15m" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "15 minutes" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "15 分钟" } } } },
    "caffeinate.settings.1h" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "1 hour" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "1 小时" } } } },
    "caffeinate.settings.2h" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "2 hours" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "2 小时" } } } },
    "caffeinate.settings.infinite" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Indefinitely" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "无限期" } } } },
    "caffeinate.settings.durationHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Used when starting from the menu; other durations stay available in the submenu." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "从菜单点击\"防休眠\"主行时使用该时长；也可在二级菜单中选择其他时长。" } } } },
    "caffeinate.settings.optionsSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Options" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "选项" } } } },
    "caffeinate.settings.preventDisplay" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Also keep the display awake" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "同时防止显示器休眠" } } } },
    "caffeinate.settings.preventDisplayHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The screen stays on too. Changes apply immediately to an active session." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开启后屏幕也不会自动关闭；变更会立即作用于当前正在生效的防休眠。" } } } },
    "windowmanager.name" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Window Manager" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "窗口管理" } } } },
    "windowmanager.menu.needAX" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Accessibility permission required (click to enable)" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "需要辅助功能权限（点击开启）" } } } },
