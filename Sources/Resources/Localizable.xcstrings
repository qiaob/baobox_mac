    "windowmanager.snapshot.namePrompt.message %lld" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Records the position and size of %lld windows. Restore them anytime from this menu." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "将记录当前 %lld 个窗口的位置与大小，之后可随时从菜单一键恢复。" } } } },
    "windowmanager.snapshot.defaultName %lld" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Layout %lld" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "布局 %lld" } } } },
    "windowmanager.snapshot.emptyCapture.title" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No windows to save" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "没有可保存的窗口" } } } },
    "windowmanager.snapshot.emptyCapture.message" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Open some windows first, then save the layout." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "先打开一些窗口，再保存布局。" } } } },
