    "screenshot.record.error.saveFailed" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The recording could not be saved" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "录制文件保存失败" } } } },
    "screenshot.record.hud.cancel" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Discard recording" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "取消录制（不保存）" } } } },
