    "screenshot.settings.historyLimit %lld" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Keep last %lld screenshots" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保留最近 %lld 张截图" } } } },
    "screenshot.settings.historyLimitHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Every capture (copy, save or pin) is kept here for quick recovery, independent of files saved to disk." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每次截图（复制/保存/贴图）都会存入历史便于找回，与保存到磁盘的文件相互独立。" } } } },
    "qrcode.name" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "QR Code" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "二维码" } } } },
