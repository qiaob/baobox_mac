    "claudecode.settings.notify.style.sound" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Sound" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "提示音" } } } },
