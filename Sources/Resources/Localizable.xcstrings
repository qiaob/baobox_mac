    "windowmanager.layout.restore" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Restore Original Position" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "恢复原始位置" } } } },
    "windowmanager.settings.layoutSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Layout" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "布局" } } } },
    "windowmanager.settings.gap %lld" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Window gap: %lld pt" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "窗口间距：%lld pt" } } } },
    "windowmanager.settings.gapHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Space kept around windows for halves, quarters and maximize; 0 means edge-to-edge." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "半屏、四分屏与最大化时在窗口四周及切分线处留出的间距；0 表示紧贴。" } } } },
    "windowmanager.settings.axDesc" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Accessibility is required to move and resize other apps' windows. Without it, actions do nothing." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "窗口管理需要辅助功能权限来移动与缩放其他 App 的窗口。未授权时动作无效。" } } } },
    "windowmanager.settings.hint" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No shortcuts are bound out of the box (the usual ⌃⌥ set collides with Rectangle). Assign your own in the Shortcuts tab. Layouts use each display's visible area and cross-display moves scale proportionally." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "出厂未绑定任何快捷键（常用的 ⌃⌥ 系列与 Rectangle 冲突），请在「快捷键」标签页按需设置。多显示器下按各屏可见区域（避开菜单栏与 Dock）分屏，跨屏移动等比映射。" } } } },
    "common.save" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Save" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保存" } } } },
    "common.delete" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "删除" } } } },
    "clipboard.settings.retention" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Auto-delete history" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "历史自动清理" } } } },
    "clipboard.settings.retention.forever" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Never" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "永不清理" } } } },
    "clipboard.settings.retention.day1" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "After 1 day" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "1 天后" } } } },
    "clipboard.settings.retention.days7" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "After 7 days" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "7 天后" } } } },
    "clipboard.settings.retention.days30" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "After 30 days" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "30 天后" } } } },
    "clipboard.settings.retention.days90" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "After 90 days" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "90 天后" } } } },
    "clipboard.settings.retentionHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Unpinned items older than this are removed automatically. Pinned items are always kept." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "超过该时长的未置顶条目会被自动清理；置顶条目始终保留。" } } } },
    "clipboard.settings.ignoredApps" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Ignored apps" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "忽略的 App" } } } },
    "clipboard.settings.ignoredEmpty" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No ignored apps yet." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暂无忽略的 App。" } } } },
    "clipboard.settings.addApp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Add App…" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "添加 App…" } } } },
    "clipboard.settings.addAppPrompt" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Ignore" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "忽略" } } } },
    "clipboard.settings.ignoredAppsHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Content copied while these apps are frontmost is never recorded." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "这些 App 在前台时复制的内容不会被记录。" } } } },
    "screenshot.history.empty" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No screenshots yet" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "暂无截图" } } } },
    "screenshot.history.pin" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Pin to Screen" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "钉到屏幕上" } } } },
    "screenshot.menu.pinFromClipboard" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Pin Image from Clipboard" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "从剪贴板贴图" } } } },
    "screenshot.menu.closeAllPins" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Close All Pins" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "关闭全部贴图" } } } },
    "screenshot.pins.noImage.title" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No image in clipboard" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "剪贴板中没有图片" } } } },
    "screenshot.pins.noImage.message" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Copy an image first, then pin it from here." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "先复制一张图片，再从这里贴到屏幕上。" } } } },
    "screenshot.settings.historySection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "History" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "历史" } } } },
    "screenshot.settings.historyLimit %lld" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Keep last %lld screenshots" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保留最近 %lld 张截图" } } } },
    "screenshot.settings.historyLimitHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Every capture (copy, save or pin) is kept here for quick recovery, independent of files saved to disk." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每次截图（复制/保存/贴图）都会存入历史便于找回，与保存到磁盘的文件相互独立。" } } } },
    "qrcode.name" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "QR Code" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "二维码" } } } },
    "qrcode.menu.generate" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Generate QR Code" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "生成二维码" } } } },
    "qrcode.hotkey.subtitle" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Opens the generator prefilled with clipboard text" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "打开生成器并自动填入剪贴板文字" } } } },
    "qrcode.panel.placeholder" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enter text or a link…" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "输入文字或链接…" } } } },
    "qrcode.panel.empty" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "The QR code appears here" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "二维码将显示在这里" } } } },
    "qrcode.panel.tooLong" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Content is too long to encode" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "内容过长，无法生成二维码" } } } },
