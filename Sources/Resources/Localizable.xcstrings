    "windowmanager.settings.snapshotEmpty" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No saved layouts. Create one via “Window Manager → Save Current Layout…” in the menu bar." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "还没有保存的布局。可在菜单栏「窗口管理 → 保存当前布局…」创建。" } } } },
