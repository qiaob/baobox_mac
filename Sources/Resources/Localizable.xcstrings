    "screenshot.record.hud.resume" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Resume recording" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "继续录制" } } } },
    "screenshot.record.mic.deniedTitle" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Microphone access is off" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "麦克风权限未开启" } } } },
    "screenshot.record.mic.deniedMessage" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable Baobox in System Settings → Privacy & Security → Microphone, then record again. This recording will continue without the microphone." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在「系统设置 → 隐私与安全性 → 麦克风」中勾选 Baobox 后重新录制；本次录制将不含麦克风声音。" } } } },
    "screenshot.settings.recordSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Recording" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "录屏" } } } },
    "screenshot.settings.recordAudio" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Record system audio" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "录制系统声音" } } } },
    "screenshot.settings.recordMic" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Record microphone" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "录制麦克风" } } } },
    "screenshot.settings.recordAudioHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Both can be toggled on the confirm bar before each recording. System audio needs no extra permission; the microphone asks once and is written as a second audio track." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "两项开关也会出现在每次录制前的确认工具条上。系统声音无需额外权限；麦克风首次开启会请求授权，声音写入独立的第二条音轨。" } } } },
    "hotkeys.none" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Not set" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "未设置" } } } },
    "clipboard.footer.delete" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "删除" } } } },
    "clipboard.row.deleteHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete this item (⌘⌫)" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "删除这条记录（⌘⌫）" } } } },
    "pin.menu.resetSize" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset to Original Size" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "恢复原始大小" } } } },
    "pin.menu.opacity" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Opacity" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "透明度" } } } },
    "screenshot.settings.format" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Output format" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "输出格式" } } } },
    "screenshot.settings.mixAudio" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Merge audio into a single track" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "混合为单条音轨" } } } },
    "screenshot.settings.mixAudioHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "With both system audio and microphone on, merging into one track plays correctly everywhere. GIF output is silent, capped at 10 fps and 720px wide — best for short clips." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "同时录系统声音与麦克风时，混为单轨可在所有播放器正常出声。GIF 输出无声音、最高 10 帧/秒、宽度缩至 720px，适合短片段。" } } } }
  }
}
