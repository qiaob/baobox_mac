    "screenshot.record.mic.deniedMessage" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enable Baobox in System Settings → Privacy & Security → Microphone, then record again. This recording will continue without the microphone." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "请在「系统设置 → 隐私与安全性 → 麦克风」中勾选 Baobox 后重新录制；本次录制将不含麦克风声音。" } } } },
    "screenshot.settings.recordSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Recording" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "录屏" } } } },
    "screenshot.settings.recordAudio" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Record system audio" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "录制系统声音" } } } },
    "screenshot.settings.recordMic" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Record microphone" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "录制麦克风" } } } },
    "screenshot.settings.recordAudioHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Both can be toggled on the confirm bar before each recording. System audio needs no extra permission; the microphone asks once and is written as a second audio track." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "两项开关也会出现在每次录制前的确认工具条上。系统声音无需额外权限；麦克风首次开启会请求授权，声音写入独立的第二条音轨。" } } } },
    "hotkeys.none" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Not set" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "未设置" } } } },
