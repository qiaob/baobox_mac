    "screenshot.menu.stopRecord" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Stop Recording" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "停止录屏" } } } },
    "screenshot.record.hotkey.subtitle" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Record full screen or a region as MP4; press again to stop" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "全屏或框选区域录制为 MP4，再按一次停止" } } } },
