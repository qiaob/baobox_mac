    "screenshot.record.bar.mic" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Microphone" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "麦克风" } } } },
    "screenshot.record.bar.start" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Start Recording" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "开始录制" } } } },
