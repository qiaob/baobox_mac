    "qrcode.settings.hint" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Generate a QR code from clipboard text or manual input (default ⌃⇧Q, changeable in the Shortcuts tab). Scan it with your phone to hand off links, or pin it on screen." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "从剪贴板文字或手动输入生成二维码（默认快捷键 ⌃⇧Q，可在「快捷键」标签页修改）。用手机扫码即可把链接传到手机，也可以把码钉在屏幕上。" } } } },
    "windowmanager.snapshot.save" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Save Current Layout…" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "保存当前布局…" } } } },
