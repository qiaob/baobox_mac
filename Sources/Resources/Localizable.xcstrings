    "claudecode.settings.config.mode.bypassWarning" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Skips every permission prompt — Claude can run anything without asking. Use with caution." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "跳过所有权限确认，Claude 可无提示执行任何操作，请谨慎。" } } } },
