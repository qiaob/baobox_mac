    "claudecode.settings.section.maintenance" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Maintenance" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "维护" } } } },
    "claudecode.settings.notify.section" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Notifications" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "通知" } } } },
    "claudecode.settings.notify.enabled" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Completion & waiting notifications" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "完成 / 等待通知" } } } },
    "claudecode.settings.notify.enabledHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Send a system notification when a task finishes or Claude awaits confirmation. Requires the Baobox event-reporting hooks below." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "任务完成或 Claude 等待确认时发送系统通知，需要下方的 Baobox 事件上报 hooks。" } } } },
    "claudecode.settings.notify.sound" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Play sound" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "提示音" } } } },
    "claudecode.settings.notify.budgetSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Usage budget" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "额度预算" } } } },
    "claudecode.settings.notify.budget" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Per-window budget (k tokens)" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "每窗口预算（千 token）" } } } },
    "claudecode.settings.notify.budgetHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Claude subscriptions limit usage per 5-hour rolling window, but the exact allowance is not published. Baobox estimates tokens used in the current window (input + output + cache) from local session logs. Enter your own estimate of how much one window allows — in thousands of tokens, e.g. 50000 = 50M — and the usage progress bar plus the 80% alert will be based on it. 0 means no budget: only usage is shown, no alert." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "Claude 订阅按「5 小时滚动窗口」限量，但官方不公布具体额度。Baobox 会从本地会话日志估算当前窗口已用的 token 总量（输入 + 输出 + 缓存）。在这里填入你自己估计的每窗口可用量作为基准（单位：千 token，如填 50000 即 5000 万），用量进度条和「达 80% 提醒」都以它为分母；填 0 表示不设预算，只展示已用量、不提醒。" } } } },
    "claudecode.settings.notify.budgetAlert" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Alert at 80% of budget" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "用量达 80% 时提醒" } } } },
    "claudecode.settings.notify.budgetRestore" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Notify when the window resets" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "额度窗口重置时提醒" } } } },
    "claudecode.settings.notify.weeklyBudget" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Weekly budget (k tokens)" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "周额度预算（k tokens）" } } } },
    "claudecode.settings.notify.weeklyFixed" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Align to fixed weekly reset" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "按固定重置时间对齐" } } } },
    "claudecode.settings.notify.weeklyWeekday" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset weekday" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "重置星期" } } } },
    "claudecode.settings.notify.weeklyHour" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Reset hour" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "重置小时" } } } },
    "claudecode.settings.notify.weeklyHint" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Match the weekly reset shown in Claude /usage; leave off for a rolling 7-day estimate" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "对照 Claude /usage 的周重置时间填写；留空按近 7 天滚动估算" } } } },
    "claudecode.settings.notify.hooksSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Event-reporting hooks" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "事件上报 hooks" } } } },
    "claudecode.settings.notify.installHooks" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Install hooks" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "安装 hooks" } } } },
    "claudecode.settings.notify.removeHooks" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Remove hooks" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "移除 hooks" } } } },
    "claudecode.settings.notify.hooksHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Installs Stop / Notification / SessionStart / UserPromptSubmit hooks that append events for Baobox to watch. Your other hooks are preserved." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "安装 Stop / Notification / SessionStart / UserPromptSubmit 事件上报 hooks 供 Baobox 监听，保留你的其他 hooks。" } } } },
