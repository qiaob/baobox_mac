    "settings.general.terminal.desc" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Used when resuming sessions from Baobox. Auto prefers installed third-party terminals (iTerm2 → Ghostty → kitty → WezTerm → Alacritty), falling back to System Terminal." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "用于从 Baobox 续接会话等命令。自动模式优先使用已安装的第三方终端（iTerm2 → Ghostty → kitty → WezTerm → Alacritty），否则用系统终端。" } } } },
    "settings.general.permissionSection" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Permissions" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "权限" } } } },
    "settings.general.screenRecording.desc" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Needed to capture screen content. The screenshot tool cannot work without it." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "用于截取屏幕内容。未授权时无法使用截图工具。" } } } },
    "settings.general.screenRecording.grantedNeedsRestart" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Enabled in System Settings — restart Baobox to apply." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "检测到系统设置中已开启，重启 Baobox 后生效。" } } } },
    "settings.general.screenRecording.notGranted" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "macOS requires restarting Baobox after you enable it in System Settings." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "系统限制：在系统设置中开启后，必须重启 Baobox 才会生效。" } } } },
    "settings.general.screenRecording.restartNow" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Restart to Apply" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "立即重启生效" } } } },
