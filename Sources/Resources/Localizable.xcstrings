    "screenshot.settings.format" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Output format" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "输出格式" } } } },
    "screenshot.settings.mixAudio" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Merge audio into a single track" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "混合为单条音轨" } } } },
    "screenshot.settings.mixAudioHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "With both system audio and microphone on, merging into one track plays correctly everywhere. GIF output is silent, capped at 10 fps and 720px wide — best for short clips." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "同时录系统声音与麦克风时，混为单轨可在所有播放器正常出声。GIF 输出无声音、最高 10 帧/秒、宽度缩至 720px，适合短片段。" } } } },
