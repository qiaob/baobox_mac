    "clipboard.settings.retentionHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Unpinned items older than this are removed automatically. Pinned items are always kept." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "超过该时长的未置顶条目会被自动清理；置顶条目始终保留。" } } } },
