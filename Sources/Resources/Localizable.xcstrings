    "windowmanager.settings.gapHelp" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Space kept around windows for halves, quarters and maximize; 0 means edge-to-edge." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "半屏、四分屏与最大化时在窗口四周及切分线处留出的间距；0 表示紧贴。" } } } },
    "windowmanager.settings.axDesc" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Accessibility is required to move and resize other apps' windows. Without it, actions do nothing." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "窗口管理需要辅助功能权限来移动与缩放其他 App 的窗口。未授权时动作无效。" } } } },
    "windowmanager.settings.hint" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "No shortcuts are bound out of the box (the usual ⌃⌥ set collides with Rectangle). Assign your own in the Shortcuts tab. Layouts use each display's visible area and cross-display moves scale proportionally." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "出厂未绑定任何快捷键（常用的 ⌃⌥ 系列与 Rectangle 冲突），请在「快捷键」标签页按需设置。多显示器下按各屏可见区域（避开菜单栏与 Dock）分屏，跨屏移动等比映射。" } } } },
