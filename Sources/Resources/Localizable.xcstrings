    "settings.about.tagline" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "A menu-bar macOS toolbox: screenshots, clipboard and more.\nAll data stays on this Mac." } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "菜单栏常驻的 macOS 效率工具集：截图 · 剪贴板。\n所有数据仅保存在本机。" } } } },
