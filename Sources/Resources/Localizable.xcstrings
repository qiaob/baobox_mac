    "windowmanager.layout.maximize" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Maximize" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "最大化" } } } },
    "windowmanager.layout.maximize.subtitle" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Fills the visible area (not full screen)" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "填满可用区域（非全屏）" } } } },
    "windowmanager.layout.center" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Center" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "居中" } } } },
    "windowmanager.layout.center.subtitle" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Keeps the current size" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "不改变尺寸" } } } },
    "windowmanager.layout.nextDisplay" : { "extractionState" : "manual", "localizations" : { "en" : { "stringUnit" : { "state" : "translated", "value" : "Move to Next Display" } }, "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "移到下一个显示器" } } } },
